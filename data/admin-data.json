          "publicLines": [
            {
              "speaker": "公共旁白",
              "text": "冰冷的雾墙在道路两端合拢，来路与去路一并消失。你们踏入了巴洛维亚。"
            },
            {
              "speaker": "公共旁白",
              "text": "雨丝打在残破路碑上，碑文被泥污遮去大半，只留下“村庄”一词仍可辨认。"
            },
            {
              "speaker": "旁白",
              "text": "夜色正在快速压下，林间偶有狼嚎，方向却始终无法判断。"
            }
          ],
          "segments": [
            {
              "groupId": "opening-all",
              "title": "【全员】迷雾中的邀请",
              "lines": [
                {
                  "speaker": "旁白",
                  "text": "一盏马灯从前方雾中缓缓靠近，持灯的青年披着湿透的斗篷。"
                },
                {
                  "speaker": "伊斯马克",
                  "text": "陌生人，如果你们还想活着过夜，就跟我进村。别在路边逗留。"
                },
                {
                  "speaker": "旁白",
                  "text": "他说话时不断回头，像在提防某种会从雾里探出的东西。"
                },
                {
                  "speaker": "伊斯马克",
                  "text": "如果你们愿意帮忙，我会告诉你们这片土地真正的主人是谁。"
                }
              ]
            }
          ]
        }
      }
